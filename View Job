<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Applied Jobs List</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #f4f6f9;
            margin: 0;
            padding: 0;
        }

        .container {
            width: 70%;
            margin: 40px auto;
            background: white;
            padding: 30px;
            border-radius: 8px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

        h2 {
            text-align: center;
            margin-bottom: 25px;
        }

        .job-card {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 18px;
            margin-bottom: 15px;
            background-color: #fdfdfd;
        }

        .job-card h3 {
            margin: 0 0 10px;
            color: #333;
        }

        .job-card p {
            margin: 5px 0;
            color: #555;
        }

        .status {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 13px;
            font-weight: bold;
            margin-top: 8px;
        }

        .pending {
            background-color: #fff3cd;
            color: #856404;
        }

        .reviewed {
            background-color: #d1ecf1;
            color: #0c5460;
        }

        .interviewing {
            background-color: #d4edda;
            color: #155724;
        }

        .rejected {
            background-color: #f8d7da;
            color: #721c24;
        }

        .empty-message {
            display: none;
            text-align: center;
            padding: 20px;
            background-color: #f8f9fa;
            border: 1px dashed #ccc;
            border-radius: 8px;
            color: #666;
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .top-bar button {
            padding: 10px 16px;
            border: none;
            border-radius: 6px;
            background-color: #007bff;
            color: white;
            cursor: pointer;
        }

        .top-bar button:hover {
            background-color: #0056b3;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="top-bar">
        <h2>My Applied Jobs</h2>
        <button onclick="toggleJobs()">Toggle View</button>
    </div>

    <div id="jobList">
        <div class="job-card">
            <h3>Software Developer</h3>
            <p><strong>Company:</strong> Tech Solutions Sdn Bhd</p>
            <p><strong>Location:</strong> Kuala Lumpur</p>
            <p><strong>Date Applied:</strong> 10 March 2026</p>
            <span class="status pending">Pending</span>
        </div>

        <div class="job-card">
            <h3>Frontend Developer</h3>
            <p><strong>Company:</strong> Web Innovate Sdn Bhd</p>
            <p><strong>Location:</strong> Selangor</p>
            <p><strong>Date Applied:</strong> 8 March 2026</p>
            <span class="status reviewed">Reviewed</span>
        </div>

        <div class="job-card">
            <h3>UI/UX Designer</h3>
            <p><strong>Company:</strong> Creative Labs</p>
            <p><strong>Location:</strong> Penang</p>
            <p><strong>Date Applied:</strong> 5 March 2026</p>
            <span class="status interviewing">Interviewing</span>
        </div>
    </div>

    <div class="empty-message" id="emptyMessage">
        No applied jobs found.
    </div>
</div>

<script>
    function toggleJobs() {
        const jobList = document.getElementById("jobList");
        const emptyMessage = document.getElementById("emptyMessage");

        if (jobList.style.display === "none") {
            jobList.style.display = "block";
            emptyMessage.style.display = "none";
        } else {
            jobList.style.display = "none";
            emptyMessage.style.display = "block";
        }
    }
</script>

</body>
</html>
